---
interface Props {
  tagline: string;
  note: string;
}

const { tagline, note } = Astro.props;

const waLink = `https://wa.me/34634080799?text=${encodeURIComponent("Hola Mamá Nancy, ¿está la casa abierta hoy?")}`;
---

<section id="inicio" class="hero">

  <!-- Nav spacer -->
  <div style="height: var(--nav-h);" aria-hidden="true"></div>

  <div class="container hero__grid">

    <!-- ── LEFT: Content ── -->
    <div class="hero__content">

      <p class="hero__eyebrow hero-anim d1">
        <span class="eyebrow__line" aria-hidden="true"></span>
        Granada · España
      </p>

      <h1 class="hero__title hero-anim d2">
        <span class="t-main">Casa Cubana</span>
        <span class="t-name">Mamá<br>Nancy</span>
      </h1>

      <p class="hero__tagline hero-anim d3">{tagline}</p>

      <div class="hero__actions hero-anim d4">
        <a href={waLink} class="btn hero__cta" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          ¿Está la casa abierta hoy?
        </a>
        <p class="hero__note">{note}</p>
      </div>
    </div>

    <!-- ── RIGHT: Vintage Travel Poster Placeholder ── -->
    <div class="hero__visual hero-anim d3">
      <div class="poster" role="img" aria-label="Cartel de viaje estilo Cuba vintage — Casa Cubana Mamá Nancy, Granada">

        <!-- Outer shadow layers -->
        <div class="poster__shadow poster__shadow--2" aria-hidden="true"></div>
        <div class="poster__shadow poster__shadow--1" aria-hidden="true"></div>

        <!-- Main poster face -->
        <div class="poster__face">

          <!-- Inner decorative border -->
          <div class="poster__border" aria-hidden="true"></div>

          <!-- Top badge -->
          <div class="poster__badge" aria-hidden="true">
            <span class="badge__est">Est.</span>
            <span class="badge__route">Habana · Granada</span>
          </div>

          <!-- Palm tree SVG -->
          <svg class="poster__palm" viewBox="0 0 240 350" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Trunk -->
            <path d="M122 348 C118 300 116 268 119 238 C122 208 126 182 130 155" stroke="#F3E7D3" stroke-width="10" stroke-linecap="round" fill="none" opacity="0.9"/>
            <path d="M128 348 C124 300 122 268 125 238 C128 208 132 182 136 155" stroke="rgba(46,36,31,0.18)" stroke-width="6" stroke-linecap="round" fill="none"/>

            <!-- Leaves — left fan -->
            <path d="M126 165 C102 138 72 112 38 95 C62 115 90 138 118 162" fill="#5E8B63"/>
            <path d="M122 175 C92 162 58 160 26 168 C58 164 92 170 120 180" fill="#5E8B63" opacity="0.72"/>

            <!-- Leaves — right fan -->
            <path d="M133 163 C158 136 190 112 218 93 C196 115 168 138 136 160" fill="#5E8B63"/>
            <path d="M136 175 C166 163 198 162 224 170 C198 165 166 172 138 182" fill="#5E8B63" opacity="0.72"/>

            <!-- Top leaf -->
            <path d="M128 158 C124 122 127 86 132 54 C134 88 132 124 130 162" fill="#5E8B63" opacity="0.9"/>

            <!-- Upper diagonal leaves -->
            <path d="M123 165 C100 143 78 115 66 82 C82 118 102 146 122 168" fill="#5E8B63" opacity="0.78"/>
            <path d="M135 163 C158 142 178 113 188 80 C174 116 155 144 137 166" fill="#5E8B63" opacity="0.78"/>

            <!-- Coconuts -->
            <circle cx="124" cy="170" r="9" fill="#D9A441"/>
            <circle cx="137" cy="175" r="8" fill="#C84C36" opacity="0.88"/>
            <circle cx="115" cy="177" r="7" fill="#D9A441" opacity="0.65"/>
          </svg>

          <!-- Bottom location text -->
          <div class="poster__location" aria-hidden="true">
            <span class="loc__city">Granada</span>
            <span class="loc__country">España</span>
          </div>

          <!-- Bottom stripe (Cuban colors) -->
          <div class="poster__stripe" aria-hidden="true">
            <span style="background: var(--color-caribbean)"></span>
            <span style="background: var(--color-rum)"></span>
            <span style="background: var(--color-sun)"></span>
          </div>

        </div><!-- /face -->
      </div><!-- /poster -->
    </div>

  </div><!-- /grid -->

  <!-- Section bottom ornament -->
  <div class="hero__ornament container" aria-hidden="true">
    <div class="ornament-row" style="color: var(--color-ink);">
      <span class="ornament-row__line"></span>
      <span class="ornament-row__glyph">✦</span>
      <span class="ornament-row__line"></span>
    </div>
  </div>

</section>

<style>
/* ---- Hero ---- */
.hero {
  background-color: var(--color-paper);
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  padding-bottom: var(--sp-12);
}

.hero__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--sp-12);
  padding-block: var(--sp-12);
  align-items: center;
}

@media (min-width: 768px) {
  .hero__grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
  }
}

@media (min-width: 1024px) {
  .hero__grid {
    grid-template-columns: 11fr 7fr;
    gap: var(--sp-20);
  }
}

/* ---- Eyebrow ---- */
.hero__eyebrow {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-rum);
  margin-bottom: var(--sp-5);
}

.eyebrow__line {
  display: block;
  width: 2rem;
  height: 1px;
  background-color: var(--color-rum);
  flex-shrink: 0;
}

/* ---- Title ---- */
.hero__title {
  font-family: var(--font-display);
  font-weight: 400;
  line-height: 0.88;
  letter-spacing: -0.02em;
  margin-bottom: var(--sp-8);
}

.t-main {
  display: block;
  font-size: clamp(2.75rem, 9vw, 6rem);
  font-style: italic;
  color: var(--color-ink);
}

.t-name {
  display: block;
  font-size: clamp(3.5rem, 12vw, 8.5rem);
  font-weight: 700;
  color: var(--color-rum);
  font-style: normal;
  margin-top: 0.06em;
}

/* ---- Tagline ---- */
.hero__tagline {
  font-family: var(--font-body);
  font-size: clamp(var(--text-base), 2vw, var(--text-xl));
  line-height: 1.8;
  color: var(--color-ink);
  opacity: 0.82;
  margin-bottom: var(--sp-10);
  max-width: 40ch;
}

/* ---- CTA ---- */
.hero__actions {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--sp-4);
}

.hero__cta {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-3);
  background-color: var(--color-caribbean);
  color: var(--color-paper);
  padding: 0.875rem 1.75rem;
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  font-weight: 500;
  letter-spacing: 0.025em;
  border-radius: var(--radius-sm);
}

.hero__cta:hover {
  background-color: var(--color-caribbean-light);
  box-shadow: 0 8px 28px rgba(13, 92, 99, 0.32);
}

.hero__note {
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: var(--color-ink-muted);
  font-style: italic;
  line-height: 1.5;
}

/* ---- Visual: Poster ---- */
.hero__visual {
  display: flex;
  justify-content: center;
  align-items: center;
}

.poster {
  position: relative;
  width: 100%;
  max-width: 310px;
}

@media (min-width: 768px) {
  .poster { max-width: 360px; }
}

/* Shadow layers */
.poster__shadow {
  position: absolute;
  inset: 0;
  border-radius: var(--radius-sm);
}

.poster__shadow--1 {
  background-color: var(--color-rum);
  transform: translate(7px, 7px);
}

.poster__shadow--2 {
  background-color: var(--color-sun);
  transform: translate(14px, 14px);
}

/* Main face */
.poster__face {
  position: relative;
  background-color: var(--color-caribbean);
  aspect-ratio: 3 / 4;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* Inner border */
.poster__border {
  position: absolute;
  inset: 10px;
  border: 1px solid rgba(243, 231, 211, 0.28);
  pointer-events: none;
}

/* Top badge */
.poster__badge {
  position: absolute;
  top: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  white-space: nowrap;
  color: var(--color-sun);
  font-family: var(--font-ui);
}

.badge__est {
  display: block;
  font-size: 0.6rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  opacity: 0.75;
}

.badge__route {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 600;
  margin-top: 2px;
}

/* Palm */
.poster__palm {
  width: 72%;
  max-width: 190px;
  position: relative;
  z-index: 1;
  margin-top: 1.5rem;
}

/* Location */
.poster__location {
  position: absolute;
  bottom: 2.25rem;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  white-space: nowrap;
  color: var(--color-paper);
  z-index: 1;
}

.loc__city {
  display: block;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 2.25rem;
  letter-spacing: 0.06em;
  line-height: 1;
}

.loc__country {
  display: block;
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  opacity: 0.6;
  margin-top: 4px;
}

/* Bottom stripe */
.poster__stripe {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 7px;
  display: flex;
}

.poster__stripe span {
  flex: 1;
}

/* ---- Bottom ornament ---- */
.hero__ornament {
  padding-top: var(--sp-8);
  padding-bottom: var(--sp-4);
}
</style>
