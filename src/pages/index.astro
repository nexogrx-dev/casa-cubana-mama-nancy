<style>
  /* ===========================
     BRAND VARIABLES
  =========================== */
  :root {
    --menta:      #A9DFBF;      /* mint green */
    --menta-dark: #7FAF9B;
    --coral:      #F08080;      /* coral */
    --naranja:    #FF8C42;      /* sunset orange */
    --crema:      #FFF8E7;      /* cream */
    --crema-dark: #F2EAD6;
    --madera:     #3B2F2F;      /* dark wood tones */
    --madera-clara:#5C4033;
    
    --texto:      #3B2F2F;
    --texto-muted:#5C4033;
    --amarillo:   #FAD02C;
    --max-w:      900px;
  }

  /* ===========================
     RESET & BASE
  =========================== */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-size: 18px;
  }

  body {
    font-family: 'Lora', Georgia, serif;
    background: var(--crema);
    color: var(--texto);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    position: relative;
  }

  /* Grain texture — analog paper feel */
  body::before {
    content: "";
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.035;
    pointer-events: none;
    z-index: 9999;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul, ol {
    list-style: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  /* ===========================
     LAYOUT HELPERS
  =========================== */
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .prose-center {
    max-width: 660px;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .section {
    padding: 6rem 0;
  }

  .section-crema    { background: var(--crema); }
  .section-menta    { background: var(--menta); color: var(--madera); }
  .section-menta .section-title--light { color: var(--madera); }
  .section-menta .section-lead--light { color: var(--texto-muted); }
  .section-menta-dark { background: var(--menta-dark); color: var(--crema); }
  .section-naranja  { background: var(--naranja); color: var(--madera); }
  .section-naranja .section-title--light { color: var(--crema); }
  .section-madera   { background: var(--madera); color: var(--crema); }
  .section-madera .section-title--light { color: var(--crema); }
  .section-coral    { background: var(--coral); color: var(--crema); }
  .section-historia { background: var(--crema-dark); }
  .section-manifesto { background: var(--menta-dark); color: var(--crema); }

  /* ===========================
     TYPOGRAPHY — headings use Playfair Display
  =========================== */
  h1, h2, h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    line-height: 1.2;
  }

  .section-title {
    font-size: clamp(1.8rem, 4.5vw, 2.75rem);
    margin-bottom: 1.25rem;
    color: var(--madera);
  }

  .section-title--light {
    color: var(--amarillo);
  }

  .section-lead {
    font-size: 1.05rem;
    color: var(--texto-muted);
    max-width: 600px;
    margin-bottom: 3rem;
    line-height: 1.8;
  }

  .section-lead--light {
    color: rgba(243, 233, 215, 0.8);
  }

  .menu-intro {
    font-style: italic;
    font-size: 1rem;
  }

  /* ===========================
     NAVIGATION
  =========================== */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--crema);
    border-bottom: 1px solid var(--crema-dark);
    box-shadow: 0 2px 16px rgba(44, 26, 14, 0.07);
  }

  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav-brand {
    font-family: 'Pacifico', cursive;
    font-size: 0.95rem;
    color: var(--naranja);
    white-space: nowrap;
    flex-shrink: 0;
