---
import Hero      from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import Casa      from '../components/Casa.astro';
import Comida    from '../components/Comida.astro';
import Tragos    from '../components/Tragos.astro';
import Memorias  from '../components/Memorias.astro';
import Reserva   from '../components/Reserva.astro';

// Global CSS (bundled by Astro)
import '../styles/tokens.css';
import '../styles/layout.css';
import '../styles/animations.css';

// Read content from research markdown files
const heroMd     = import.meta.glob('../../research/hero.md',     { eager: true });
const nancyMd    = import.meta.glob('../../research/nancy.md',    { eager: true });
const casaMd     = import.meta.glob('../../research/casa.md',     { eager: true });
const comidaMd   = import.meta.glob('../../research/comida.md',   { eager: true });
const coctelesMd = import.meta.glob('../../research/cocteles.md', { eager: true });

const hero     = (Object.values(heroMd)[0]     as any).frontmatter;
const nancy    = (Object.values(nancyMd)[0]    as any).frontmatter;
const casa     = (Object.values(casaMd)[0]     as any).frontmatter;
const comida   = (Object.values(comidaMd)[0]   as any).frontmatter;
const cocteles = (Object.values(coctelesMd)[0] as any).frontmatter;

const waLink = `https://wa.me/34634080799?text=${encodeURIComponent("Hola Mamá Nancy, ¿está la casa abierta hoy?")}`;

const siteName = "Casa Cubana Mamá Nancy";
const siteDesc = "Bar cubano en Granada. La cocina de Nancy: mojitos, ropa vieja y conversación. No es un restaurante — es su casa.";
const canonical = "https://casacubana-mama-nancy.pages.dev/";
---

<!DOCTYPE html>
<html lang="es" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={siteDesc} />
  <title>{siteName} — Granada</title>
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={siteName} />
  <meta property="og:description" content={siteDesc} />
  <meta property="og:image"       content="/images/hero.webp" />
  <meta property="og:locale"      content="es_ES" />

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={siteName} />
  <meta name="twitter:description" content={siteDesc} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts: preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Fonts: load -->
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600&family=Caveat:wght@400;700&display=swap"
    rel="stylesheet"
  />

  <!-- JSON-LD -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "Casa Cubana Mamá Nancy",
      "description": "Bar cubano en Granada con cocina casera cubana y cócteles.",
      "url": "https://casacubana-mama-nancy.pages.dev",
      "telephone": "+34634080799",
      "servesCuisine": ["Cubana", "Caribeña"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Calle Duquesa 31",
        "addressLocality": "Granada",
        "postalCode": "18001",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 37.1786553,
        "longitude": -3.6031193
      },
      "sameAs": ["https://www.instagram.com/cafebarmamanancy"]
    }
  </script>
</head>

<body>

  <!-- ═══════════════════════════════════
       NAVIGATION
  ═══════════════════════════════════ -->
  <header class="nav" id="nav">
    <div class="container nav__inner">

      <!-- Brand -->
      <a href="#inicio" class="nav__brand" aria-label="Ir al inicio">
        <span class="brand__name">Nancy</span>
        <span class="brand__tag">Granada</span>
      </a>

      <!-- Desktop nav links -->
      <nav class="nav__links" aria-label="Navegación principal">
        <a href="#la-casa">La Casa</a>
        <a href="#comida">La Mesa</a>
        <a href="#tragos">Los Tragos</a>
        <a href="#memorias">Memorias</a>
        <a href="#reserva" class="nav__cta-link">Escríbeme</a>
      </nav>

      <!-- Mobile: WhatsApp icon -->
      <a href={waLink} class="nav__wa-mobile" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>

    </div>
  </header>

  <!-- ═══════════════════════════════════
       MAIN CONTENT
  ═══════════════════════════════════ -->
  <main id="main">
    <Hero      tagline={hero.tagline}    note={hero.note} />
    <Manifesto quote={nancy.quote} />
    <Casa      highlight={casa.highlight} />
    <Comida    intro={comida.intro}      items={comida.items} />
    <Tragos    intro={cocteles.intro}    items={cocteles.items} />
    <Memorias />
    <Reserva />
  </main>

  <!-- ═══════════════════════════════════
       FOOTER
  ═══════════════════════════════════ -->
  <footer class="footer">
    <div class="container footer__inner">
      <p class="footer__brand">Casa Cubana Mamá Nancy</p>
      <p class="footer__address">Calle Duquesa 31 · Granada · España</p>
      <div class="footer__links">
        <a href={waLink} target="_blank" rel="noopener">WhatsApp</a>
        <span aria-hidden="true">·</span>
        <a href="https://instagram.com/cafebarmamanancy" target="_blank" rel="noopener">Instagram</a>
        <span aria-hidden="true">·</span>
        <a href="https://maps.google.com/?q=37.1786553,-3.6031193" target="_blank" rel="noopener">Cómo llegar</a>
      </div>
      <p class="footer__copy">© {new Date().getFullYear()} Casa Cubana Mamá Nancy</p>
    </div>
  </footer>

  <!-- ═══════════════════════════════════
       FLOATING WHATSAPP
  ═══════════════════════════════════ -->
  <a href={waLink} class="float-wa" target="_blank" rel="noopener noreferrer" aria-label="Escríbeme por WhatsApp">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="float-wa__label">¿Está abierta?</span>
  </a>

</body>
</html>

<style is:global>
  /* ---- Navigation ---- */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    background-color: rgba(243, 231, 211, 0.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(46, 36, 31, 0.07);
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
  }

  .nav.scrolled {
    background-color: rgba(243, 231, 211, 0.97);
    box-shadow: 0 2px 20px rgba(46, 36, 31, 0.09);
  }

  .nav__inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__brand {
    display: flex;
    flex-direction: column;
    line-height: 1;
    gap: 1px;
    text-decoration: none;
  }

  .brand__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .brand__tag {
    font-family: var(--font-ui);
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-rum);
    opacity: 0.8;
  }

  .nav__links {
    display: none;
    align-items: center;
    gap: var(--sp-8);
  }

  @media (min-width: 768px) {
    .nav__links { display: flex; }
  }

  .nav__links a {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    letter-spacing: 0.03em;
    color: var(--color-ink);
    opacity: 0.7;
    transition: opacity 0.2s ease;
    text-decoration: none;
  }

  .nav__links a:hover { opacity: 1; }

  .nav__cta-link {
    background-color: var(--color-caribbean) !important;
    color: var(--color-paper) !important;
    opacity: 1 !important;
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-sm);
    font-weight: 500 !important;
    transition: background-color 0.2s ease !important;
  }

  .nav__cta-link:hover {
    background-color: var(--color-caribbean-light) !important;
  }

  .nav__wa-mobile {
    display: flex;
    align-items: center;
    color: var(--color-caribbean);
  }

  @media (min-width: 768px) {
    .nav__wa-mobile { display: none; }
  }

  /* ---- Footer ---- */
  .footer {
    background-color: var(--color-ink);
    color: var(--color-paper);
    padding-block: var(--sp-12);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-4);
  }

  .footer__brand {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-style: italic;
  }

  .footer__address {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(243, 231, 211, 0.45);
  }

  .footer__links {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: rgba(243, 231, 211, 0.55);
  }

  .footer__links a {
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__links a:hover { color: var(--color-sun); }

  .footer__copy {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: rgba(243, 231, 211, 0.25);
    margin-top: var(--sp-4);
  }

  /* ---- Floating WhatsApp ---- */
  .float-wa {
    position: fixed;
    bottom: 1.5rem;
    right: 1.25rem;
    z-index: 90;
    background-color: #25D366;
    color: #fff;
    border-radius: 999px;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 0.8rem 1.1rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.22);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.2s var(--ease-out), box-shadow 0.2s ease;
  }

  .float-wa:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 8px 28px rgba(37, 211, 102, 0.4);
  }

  .float-wa__label {
    display: none;
  }

  @media (min-width: 640px) {
    .float-wa__label { display: block; }
  }
</style>

<script>
  // ---- Scroll-reveal via IntersectionObserver ----
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.08,
      rootMargin: '0px 0px -48px 0px',
    }
  );

  document
    .querySelectorAll('.reveal, .reveal-left, .reveal-right')
    .forEach((el) => revealObserver.observe(el));

  // ---- Nav scroll state ----
  const nav = document.getElementById('nav');

  const updateNav = () => {
    if (!nav) return;
    nav.classList.toggle('scrolled', window.scrollY > 24);
  };

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
