<style>
  /* ===========================
     CUBAN HOUSE VARIABLES
  =========================== */
  :root {
    /* Cuban colors */
    --azul:        #1B4F8A;
    --azul-dark:   #143D6B;
    --azul-light:  #2A6CB8;
    --rojo:        #C0392B;
    --rojo-dark:   #962D22;
    --amarillo:    #F4D03F;
    --amarillo-dark:#D4B02F;

    /* Warm neutrals */
    --crema:       #FDF6E3;
    --crema-dark:  #F0E6CC;
    --warm-white:  #FAF3E0;
    --papel:       #F5ECD5;

    /* Wood / text */
    --madera:      #3B2F2F;
    --madera-light:#5C4033;

    /* Layout */
    --max-w:       960px;
  }

  /* ===========================
     RESET & BASE
  =========================== */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-size: 18px;
  }

  body {
    font-family: 'Lora', Georgia, serif;
    background: var(--warm-white);
    color: var(--madera);
    line-height: 1.85;
    -webkit-font-smoothing: antialiased;
  }

  /* Aged paper grain */
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.04;
    pointer-events: none;
    z-index: 9999;
  }

  a { color: inherit; text-decoration: none; }
  ul, ol { list-style: none; }
  img { max-width: 100%; height: auto; }

  p {
    max-width: 66ch;
    margin-bottom: 1.25rem;
  }

  /* ===========================
     HANDWRITTEN FONT
  =========================== */
  .handwritten {
    font-family: 'Caveat', cursive;
    font-weight: 700;
  }

  /* ===========================
     LAYOUT
  =========================== */
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section {
    padding: 6rem 0;
    position: relative;
  }

  .section-cream { background: var(--crema); }
  .section-warm  { background: var(--papel); }
  .section-blue  { background: var(--azul); color: var(--crema); }
  .section-blue-dark { background: var(--azul-dark); color: var(--crema); }

  /* ===========================
     TYPOGRAPHY
  =========================== */
  h1, h2, h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    line-height: 1.2;
  }

  .section-heading {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    margin-bottom: 0.75rem;
    color: var(--madera);
  }

  .section-heading--light {
    color: var(--amarillo);
  }

  .heading-accent {
    font-style: italic;
    color: var(--rojo);
  }

  .section-intro {
    font-size: 1.3rem;
    color: var(--madera-light);
    margin-bottom: 3rem;
    max-width: 500px;
  }

  .section-intro--light {
